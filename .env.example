DATABASE_URL="postgresql://postgres:postgres@localhost:5432/clipper_web?schema=public"
CREDENTIAL_ENCRYPTION_KEY="change-this-to-a-long-random-secret"
SINGLE_OWNER_REF="self"
APP_PASSWORD="change-this-password"
SESSION_SECRET="change-this-session-secret"
LOCAL_VIDEO_STORAGE_DIR="storage"
GROQ_TRANSCRIBE_MODEL="whisper-large-v3-turbo"
GROQ_TRANSCRIBE_MAX_UPLOAD_BYTES="25165824"
GROQ_TRANSCRIBE_CHUNK_SECONDS="480"
FFMPEG_PATH="ffmpeg"
FFPROBE_PATH="ffprobe"
SUBTITLE_FONTS_DIR=""
GROQ_HIGHLIGHT_MODEL="openai/gpt-oss-120b"
GROQ_CHAT_ENDPOINT="https://api.groq.com/openai/v1/chat/completions"
PYTHON_BIN=".venv/bin/python"
FACE_CROP_SCRIPT_PATH="face-detection/crop_plan.py"
FACE_DETECTION_SAMPLE_FPS="2"
LOG_LEVEL="info"
YOUTUBE_USER_AGENT="Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
YOUTUBE_COOKIES_FILE="cookie.json"
YOUTUBE_COOKIES_JSON=""
YOUTUBE_COOKIES_BASE64=""
YOUTUBE_PROXY_URL=""
YOUTUBE_GETINFO_MAX_RETRIES="2"
YOUTUBE_RETRY_BASE_MS="1200"
YOUTUBE_ENABLE_YTDLP_FALLBACK="true"
YTDLP_BIN="yt-dlp"
YTDLP_JS_RUNTIME="node"
